# Figma OAuth 2.0 App credentials
# Create an OAuth app at: https://www.figma.com/developers/apps
FIGMA_CLIENT_ID=your_oauth_client_id_here
FIGMA_CLIENT_SECRET=your_oauth_client_secret_here

# The redirect URI registered in your Figma OAuth app
# Must match exactly what you configured in the app settings
FIGMA_REDIRECT_URI=https://your-app.example.com/oauth/callback

# Figma SCIM API token — required for user/group management tools
# OAuth has no scope for SCIM; this token is separate.
# Obtain from: Figma Admin console → Security → SCIM provisioning (Enterprise plan required)
FIGMA_SCIM_TOKEN=your_scim_api_token_here

# Figma organization ID
# Find at: Figma Admin → Settings (the number in the URL or on the settings page)
FIGMA_ORG_ID=your_organization_id_here

# Optional: personal access token to bypass OAuth for REST API calls
# If set, this overrides OAuth for Payments and Activity Logs tools.
# Useful for testing or environments where OAuth flow is not possible.
# Leave commented out to use OAuth (recommended for production).
# FIGMA_ACCESS_TOKEN=your_personal_access_token_here
