# ── Authentication (choose one) ─────────────────────────────────────────────
#
# Option A — OAuth 2.0 (recommended): uses your published Figma app.
# After one browser authorization, tokens are stored and silently refreshed
# using Client ID + Secret. Refresh tokens do not expire.
# Create an OAuth app at: https://www.figma.com/developers/apps
FIGMA_CLIENT_ID=your_oauth_client_id_here
FIGMA_CLIENT_SECRET=your_oauth_client_secret_here
FIGMA_REDIRECT_URI=https://localhost
#
# Option B — Personal Access Token: simpler, never expires, no browser flow.
# If set, this overrides OAuth for all REST API calls.
# Create at: https://www.figma.com/settings → Personal access tokens
# FIGMA_ACCESS_TOKEN=your_personal_access_token_here

# ── SCIM (Enterprise plan only) ─────────────────────────────────────────────
# Obtain from: Figma Admin → Security → SCIM provisioning
FIGMA_SCIM_TOKEN=your_scim_api_token_here

# ── Organization & Team IDs ──────────────────────────────────────────────────
# FIGMA_ORG_ID: used for Activity Logs API (Organization/Enterprise plans)
# Find at: Figma Admin → Settings
FIGMA_ORG_ID=your_organization_id_here

# FIGMA_TEAM_ID: used for Teams Members API (all plans including Pro)
# Find in the Figma URL: figma.com/files/team/{TEAM_ID}/...
FIGMA_TEAM_ID=your_team_id_here
